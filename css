body {
  font-family: Arial, sans-serif;
  text-align: center;
  background: #f4f4f4;
}
h1 {
  color: #333;
}
input {
  padding: 8px;
  margin: 5px;
}
button {
  padding: 8px 12px;
  background: #007BFF;
  color: white;
  border: none;
  cursor: pointer;
}
ul {
  list-style: none;
  padding: 0;
}
li {
  margin: 8px;
}
